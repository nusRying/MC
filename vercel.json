{
  "version": 2,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'unsafe-inline' 'unsafe-eval' blob:; connect-src *; img-src * data: blob:; frame-src *; style-src * 'unsafe-inline'; font-src * data:;"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/mcp/(.*)",
      "destination": "/api/mcp.js"
    },
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/api/mcp.js"
    },
    {
      "source": "/callback",
      "destination": "/index.html"
    }
  ]
}
