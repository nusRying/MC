{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/mcp/(.*)",
      "destination": "/api/mcp.js"
    },
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/api/mcp.js"
    },
    {
      "source": "/callback",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
