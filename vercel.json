{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "mcp-server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/.well-known/oauth-protected-resource",
      "dest": "mcp-server/index.js"
    },
    {
      "src": "/mcp/(.*)",
      "dest": "mcp-server/index.js"
    },
    {
      "src": "/sse",
      "dest": "mcp-server/index.js"
    },
    {
      "src": "/messages",
      "dest": "mcp-server/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/callback",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
